// Simple test program for Peregrine CPU
// Assembler output - basic ALU operations test
// Addresses in hex, data in hex

// Address 0x0000: ADDI x1, x0, 5      (x1 = 5)
// 000000000101_00000_000_00001_0010011
@00000000
00000005

// Address 0x0004: ADDI x2, x0, 3      (x2 = 3)
// 000000000011_00000_000_00010_0010011
@00000004
00000003

// Address 0x0008: ADD  x3, x1, x2     (x3 = x1 + x2 = 8)
// 0000000_00010_00001_000_00011_0110011
@00000008
002081B3

// Address 0x000C: SUB  x4, x1, x2     (x4 = x1 - x2 = 2)
// 0100000_00010_00001_000_00100_0110011
@0000000C
40208233

// Address 0x0010: AND  x5, x1, x2     (x5 = x1 & x2)
// 0000000_00010_00001_111_00101_0110011
@00000010
0020F2B3

// Address 0x0014: OR   x6, x1, x2     (x6 = x1 | x2)
// 0000000_00010_00001_110_00110_0110011
@00000014
0020E333

// Address 0x0018: XOR  x7, x1, x2     (x7 = x1 ^ x2)
// 0000000_00010_00001_100_00111_0110011
@00000018
0020C3B3

// Address 0x001C: NOP (loop forever)
// 000000000000_00000_000_00000_0010011
@0000001C
00000013
